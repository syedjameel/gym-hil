<mujoco model="PandaUSBInsertionScene">
    <include file="panda.xml"/>

    <option timestep=".002" noslip_iterations="5" noslip_tolerance="0"/>

    <statistic center="0.4 0 0.2" extent="0.8"/>

    <visual>
      <headlight diffuse=".5 .5 .5" ambient=".5 .5 .5"/>
      <global azimuth="160" elevation="-20" offheight="128" offwidth="128"/>
      <quality offsamples="8"/>
    </visual>

    <asset>
      <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
      <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.9 0.9 0.9" rgb2=".85 .85 .85"/>
      <material name="grid" texture="grid" texrepeat="2 2" texuniform="true" reflectance="0"/>
      <material name="wood" rgba="0.55 0.40 0.27 1"/>
      <material name="white_glow" rgba="1 1 1 1" emission="0.5"/>
    </asset>

    <worldbody>
      <!-- Cameras -->
      <!-- Near top-down above USB port, ~20deg tilt toward gripper (-X) -->
      <camera name="front" pos="0.57 0.0 0.15" xyaxes="0.94 0 -0.34 0 1 0" fovy="45"/>
      <!-- Side camera: looks at workspace from -Y side -->
      <camera name="side" pos="0.53 -0.15 0.065" xyaxes="1 0 0 0 0 1" fovy="45"/>

      <!-- Ground plane (below the table) -->
      <geom name="floor" size="3 3 0.01" type="plane" material="grid"/>

      <!-- Realistic table: 80x80 cm, 4 cm thick slab, top surface at world z=0.04 -->
      <geom name="table_top" type="box" size="0.40 0.40 0.02" pos="0.45 0 0.02"
            material="wood" friction="1.0 0.005 0.0001"/>

      <!-- USB-A connector (graspable, freejoint) -->
      <body name="usb_connector" pos="0.52 0 0.044">
        <freejoint name="usb_connector"/>
        <geom name="shell_top"     pos="-0.006 0 0.0021"     size="0.006 0.006 0.00015"   type="box" solimp="0.998 0.998 0.001" solref="0.02 1" density="8000" friction="0.9 0.1 0.01" condim="4" rgba="0.72 0.72 0.76 1"/>
        <geom name="shell_bottom"  pos="-0.006 0 -0.0021"    size="0.006 0.006 0.00015"   type="box" solimp="0.998 0.998 0.001" solref="0.02 1" density="8000" friction="0.9 0.1 0.01" condim="4" rgba="0.72 0.72 0.76 1"/>
        <geom name="shell_left"    pos="-0.006 -0.00585 0"   size="0.006 0.00015 0.00195" type="box" solimp="0.998 0.998 0.001" solref="0.02 1" density="8000" friction="0.9 0.1 0.01" condim="4" rgba="0.72 0.72 0.76 1"/>
        <geom name="shell_right"   pos="-0.006 0.00585 0"    size="0.006 0.00015 0.00195" type="box" solimp="0.998 0.998 0.001" solref="0.02 1" density="8000" friction="0.9 0.1 0.01" condim="4" rgba="0.72 0.72 0.76 1"/>
        <geom name="shell_back"    pos="-0.01185 0 0"        size="0.00015 0.006 0.00225" type="box" solimp="0.998 0.998 0.001" solref="0.02 1" density="8000" friction="0.9 0.1 0.01" condim="4" rgba="0.72 0.72 0.76 1"/>
        <geom name="contact_strip" pos="-0.005 0 0.00155"    size="0.004 0.004 0.0004"    type="box" solimp="0.998 0.998 0.001" solref="0.02 1" density="1300" friction="0.9 0.01 0.0005" condim="4" rgba="0.85 0.82 0.55 1"/>
        <geom name="overmold"      pos="-0.020 0 0"          size="0.008 0.008 0.004"     type="box" solimp="0.998 0.998 0.001" solref="0.02 1" density="1300" friction="1.1 0.15 0.02" condim="4" rgba="0.1 0.1 0.12 1"/>
        <geom name="strain_relief" pos="-0.032 0 0"          size="0.004 0.005 0.003"     type="box" solimp="0.998 0.998 0.001" solref="0.02 1" density="900"  friction="1.0 0.1 0.01" condim="4" rgba="0.08 0.08 0.10 1"/>
        <geom name="cable_stub"    fromto="-0.036 0 0 -0.060 0 0" size="0.0025"           type="cylinder" solimp="0.998 0.998 0.001" solref="0.02 1" density="600" friction="1.0 0.1 0.01" condim="4" rgba="0.05 0.05 0.07 1"/>
        <!-- Grasp target at overmold center; also used by the usb_connector_pos sensor -->
        <site name="usb_grasp"    pos="-0.020 0 0" size="0.003" rgba="0 1 0 0.5"/>
        <!-- Plug tip; used by the usb_plug_pos sensor. -->
        <site name="usb_plug_tip" pos="0 0 0"      size="0.002" rgba="1 0 0 0.5"/>
      </body>

      <!-- USB-A port mounted on a dev-board-style enclosure sitting on the table -->
      <body name="usb_port_fixture" pos="0.53 0 0.065">
        <geom name="port_wall_top"    pos="0.0065 0 0.0057"        size="0.0065 0.012 0.0033"    type="box" solimp="0.998 0.998 0.0005" solref="0.02 1" friction="1 0.005 0.0001" condim="4" rgba="0.2 0.2 0.24 1" material="white_glow"/>

        <geom name="port_wall_bottom" pos="0.0065 0 -0.0057"        size="0.0065 0.012 0.0033"    type="box" solimp="0.998 0.998 0.0005" solref="0.02 1" friction="1 0.005 0.0001" condim="4" rgba="0.2 0.2 0.24 1" material="white_glow"/>
        <geom name="port_wall_left"   pos="0.0065 -0.009075 -0.0"  size="0.0065 0.002925 0.0024" type="box" solimp="0.998 0.998 0.0005" solref="0.02 1" friction="1 0.005 0.0001" condim="4" rgba="0.2 0.2 0.24 1" material="white_glow"/>
        <geom name="port_wall_right"  pos="0.0065 0.009075 -0.0"   size="0.0065 0.002925 0.0024" type="box" solimp="0.998 0.998 0.0005" solref="0.02 1" friction="1 0.005 0.0001" condim="4" rgba="0.2 0.2 0.24 1" material="white_glow"/>
        <geom name="port_back"        pos="0.0145 0 -0.0"          size="0.0015 0.012 0.009"     type="box" solimp="0.998 0.998 0.0005" solref="0.02 1" friction="1 0.005 0.0001" condim="4" rgba="0.2 0.2 0.24 1" material="white_glow"/>
        <geom name="port_tongue"      pos="0.008 0 -0.00105"        size="0.005 0.005 0.0009"     type="box" solimp="0.998 0.998 0.0005" solref="0.02 1" friction="0.9 0.01 0.0005" condim="4" rgba="0.9 0.9 0.92 1"/>
        <geom name="device_body"      pos="0.031 0 -0.02"           size="0.015 0.030 0.030"      type="box" solimp="0.998 0.998 0.0005" solref="0.02 1" friction="1 0.005 0.0001" condim="4" rgba="0.78 0.76 0.70 1"/>
        <geom name="front_bezel"      pos="0.017 0 0"           size="0.002 0.018 0.012"      type="box" solimp="0.998 0.998 0.0005" solref="0.02 1" friction="1 0.005 0.0001" condim="4" rgba="0.30 0.30 0.34 1" />

        <!-- Entry: cavity mouth (faces the robot along -X). -->
        <site name="usb_port_entry"  pos="0 0 0"     size="0.003" rgba="0 1 0 0.5"/>
        <!-- Bottom: inside of the back wall (full-insertion target). -->
        <site name="usb_port_bottom" pos="0.013 0 0.0" size="0.003" rgba="1 0 0 0.5"/>
      </body>


      <!-- Mocap target body for opspace controller -->
      <body name="target" pos="0.4 0 0.3" quat="0 1 0 0" mocap="true">
        <geom name="target" type="box" size=".03 .03 .03"
              contype="0" conaffinity="0" rgba=".6 .3 .3 0"/>
      </body>
    </worldbody>

    <sensor>
      <framepos  name="usb_connector_pos"   objtype="site" objname="usb_grasp"/>
      <framequat name="usb_connector_quat"  objtype="body" objname="usb_connector"/>
      <framepos  name="usb_plug_pos"        objtype="site" objname="usb_plug_tip"/>
      <framepos  name="usb_port_entry_pos"  objtype="site" objname="usb_port_entry"/>
      <framepos  name="usb_port_bottom_pos" objtype="site" objname="usb_port_bottom"/>
    </sensor>
</mujoco>
