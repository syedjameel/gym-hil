<mujoco model="PandaUSBInsertionScene">
    <include file="panda.xml"/>

    <option timestep=".002" noslip_iterations="5" noslip_tolerance="0"/>

    <statistic center="0.4 0 0.2" extent="0.8"/>

    <visual>
      <headlight diffuse=".5 .5 .5" ambient=".5 .5 .5"/>
      <global azimuth="160" elevation="-20" offheight="128" offwidth="128"/>
      <quality offsamples="8"/>
    </visual>

    <asset>
      <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
      <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1="0.9 0.9 0.9" rgb2=".85 .85 .85"/>
      <material name="grid" texture="grid" texrepeat="2 2" texuniform="true" reflectance="0"/>
      <material name="usb_plastic" rgba="0.0 0.0 0.75 1"/>
      <material name="usb_metal" rgba="0.75 0.0 0.0 1"/>
      <material name="port_housing" rgba="0.2 0.2 0.2 1"/>
      <material name="port_inner" rgba="0.2 0.2 0.2 1"/>
      <material name="fixture_gray" rgba="0.2 0.2 0.2 1"/>
    </asset>

    <worldbody>
      <!-- Cameras -->
      <camera name="front" pos="0.75 0.0 0.2" quat="0.5963678 0.3799282 0.3799282 0.5963678" fovy="45"/>
      <!-- Side camera: looks at workspace from -Y side, tilted ~25 degrees down
           for an isometric-style 3/4 view of the insertion. -->
      <camera name="side" pos="0.5 -0.12 0.12" xyaxes="1 0 0 0 0.574 0.819" fovy="45"/>

      <!-- Floor / table surface -->
      <geom name="floor" size="3 3 0.01" type="plane" material="grid"/>

      <!--
        USB Connector (graspable, freejoint).
        Larger blocky body (25x25x30mm) + small light plug stub pointing +X.
        Sized so the Robotiq 2F-85 finger pads (~22mm wide x 30mm tall) get
        nearly full contact on the +/-Y faces - much more stable than a tiny
        15mm cube. Grasp site at the body center coincides with the COM
        (the small light plug barely shifts the COM), so the connector does
        NOT tilt under gravity when lifted.
      -->
      <body name="usb_connector" pos="0.49 0.0 0.015">
        <freejoint name="usb_connector"/>
        <!-- Body: 25mm (X) x 25mm (Y) x 30mm (Z), heavy enough that the
             small plug barely shifts the COM (COM_X ~= 1.3mm, well inside). -->
        <geom name="usb_body" type="box" size="0.0125 0.0125 0.015"
              mass="0.040" material="usb_plastic" friction="1.0 0.005 0.0001"/>
        <!-- Plug stub: 20x10x8mm, light, extends from the +X face of the body.
             The 20mm length matches the 20mm slot depth so the plug fills
             the entire slot in X at full insertion - no rotational play,
             body cannot tilt out from the port.
             Plug center X = 0.0125 (body edge) + 0.010 (plug half-length) = 0.0225 -->
        <geom name="usb_plug" type="box" size="0.010 0.005 0.004"
              mass="0.003" material="usb_metal" pos="0.0225 0 0"
              friction="0.5 0.005 0.0001"/>
        <!-- Grasp site at the body center (essentially at the COM) -->
        <site name="usb_grasp" pos="0 0 0" size="0.005"/>
      </body>
      <!--
        USB Port - floating in air, no surrounding wall.
        Five thin walls form a horizontal rectangular tube fixed to worldbody
        at (0.55, 0, 0.05) - 5cm above the table.
        Slot opens on the -X face (facing the robot). Insertion direction: +X.
        Channel interior: 16mm wide (Y) x 8.5mm tall (Z), 20mm deep (X).
        Plug is 10mm wide x 8mm tall x 20mm long, so this gives 3mm Y
        clearance and 0.25mm Z clearance per side. The 20mm plug fills
        the slot in X at full insertion, eliminating cantilever droop.
      -->
      <body name="usb_port_fixture" pos="0.55 0.0 0.05">
        <!-- Top wall of slot (Y half 0.010 seals the wider channel) -->
        <geom name="port_wall_top" type="box" size="0.010 0.010 0.001"
              pos="0 0 0.00525" material="port_inner"
              friction="0.5 0.005 0.0001" condim="4"
              solimp="0.95 0.99 0.001" solref="0.004 1"/>
        <!-- Bottom wall -->
        <geom name="port_wall_bottom" type="box" size="0.010 0.010 0.001"
              pos="0 0 -0.00525" material="port_inner"
              friction="0.5 0.005 0.0001" condim="4"
              solimp="0.95 0.99 0.001" solref="0.004 1"/>
        <!-- Left side wall (along +Y, Z half sized to seal the 8.5mm channel) -->
        <geom name="port_wall_left" type="box" size="0.010 0.001 0.00425"
              pos="0 0.009 0" material="port_inner"
              friction="0.5 0.005 0.0001" condim="4"
              solimp="0.95 0.99 0.001" solref="0.004 1"/>
        <!-- Right side wall (along -Y) -->
        <geom name="port_wall_right" type="box" size="0.010 0.001 0.00425"
              pos="0 -0.009 0" material="port_inner"
              friction="0.5 0.005 0.0001" condim="4"
              solimp="0.95 0.99 0.001" solref="0.004 1"/>
        <!-- Back wall (stops insertion at full depth, sized to seal the new channel) -->
        <geom name="port_back" type="box" size="0.001 0.010 0.00425"
              pos="0.011 0 0" material="port_inner"
              solimp="0.95 0.99 0.001" solref="0.004 1"/>

        <!--
          Support structure: gives the port visual mass so the ResNet encoder
          has a stable, distinctive feature to lock onto (instead of 5 floating
          thin walls). A vertical post on the +X side of the slot, mounted on
          a small base plate sitting on the table. The post is welded to the
          port walls via this body so the slot stays exactly where it was.
        -->
        <!-- Vertical post: 10x8mm cross section, runs from the floor (body
             Z=-0.05) up to just above the top of the back wall (body Z=+0.004).
             Centered slightly behind the back wall and overlapping it slightly
             so the two geoms visually merge into one housing. -->
        <geom name="port_post" type="box" size="0.005 0.004 0.027"
              pos="0.013 0 -0.023" material="fixture_gray"/>
        <!-- Base plate: 28x28mm footprint, 2mm thick, sitting on the table
             directly under the post. -->
        <geom name="port_base" type="box" size="0.014 0.014 0.001"
              pos="0.013 0 -0.049" material="fixture_gray"/>

        <!-- Sites for reward computation -->
        <!-- Entry: at the -X face where the slot opens (faces robot) -->
        <site name="usb_port_entry" pos="-0.011 0 0" size="0.003" rgba="0 1 0 0.5"/>
        <!-- Bottom: where the plug center ends up at full insertion. With a
             20mm plug filling a 20mm slot, the plug center sits at body-local
             X=0 when the plug back face touches the back wall. -->
        <site name="usb_port_bottom" pos="0.000 0 0" size="0.003" rgba="1 0 0 0.5"/>
      </body>

      <!-- Mocap target body for opspace controller -->
      <body name="target" pos="0.4 0 0.3" quat="0 1 0 0" mocap="true">
        <geom name="target" type="box" size=".03 .03 .03"
              contype="0" conaffinity="0" rgba=".6 .3 .3 0"/>
      </body>
    </worldbody>

    <sensor>
      <framepos name="usb_connector_pos" objtype="site" objname="usb_grasp"/>
      <framequat name="usb_connector_quat" objtype="body" objname="usb_connector"/>
      <framepos name="usb_plug_pos" objtype="geom" objname="usb_plug"/>
      <framepos name="usb_port_entry_pos" objtype="site" objname="usb_port_entry"/>
      <framepos name="usb_port_bottom_pos" objtype="site" objname="usb_port_bottom"/>
    </sensor>
</mujoco>
